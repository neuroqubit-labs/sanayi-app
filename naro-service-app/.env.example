EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_APP_ENV=development

# Geliştirme modunda OTP'yi bypass eder, splash sonrası tabs'e yönlenir.
# Gerçek backend ile test ederken "false" yap veya satırı yorum yap.
EXPO_PUBLIC_MOCK_AUTH=true

# Mock modda onay durumu. "pending" yaparsan onboarding/pending ekranına gider,
# "active" ise direkt tabs. Sadece EXPO_PUBLIC_MOCK_AUTH=true iken geçerli.
EXPO_PUBLIC_MOCK_APPROVAL=active
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
