# =============================================================================
# Root .gitignore — Naro çok-projeli repo
# Her alt proje bağımsız çalışır; ortak kurallar burada, projeye özel kurallar
# ilgili alt klasörün kendi .gitignore dosyasında tanımlanır.
# =============================================================================

# ---- Node / JavaScript (naro-app, naro-service-app) ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store/
**/.pnpm-store/
packages/*/dist/

# ---- Expo / React Native ----
.expo/
.expo-shared/
dist/
web-build/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# ---- Python / FastAPI (naro-backend) ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/

# ---- Docker volume mounts ----
**/postgres-data/
**/redis-data/

# ---- Environment ----
.env
.env.local
.env.*.local
!.env.example

# ---- Build output ----
build/
*.min.js
*.min.css

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db
*.Zone.Identifier

# ---- Agent tooling ----
.gemini/
.codex
.claude/

# ---- Logs ----
*.log
logs/
