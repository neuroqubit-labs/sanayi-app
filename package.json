{
  "name": "naro-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:app": "pnpm --filter naro-app start",
    "dev:service": "pnpm --filter naro-service-app start",
    "capture:legacy-screens": "node scripts/capture-legacy-screens.mjs",
    "test": "pnpm -r --parallel --if-present test",
    "typecheck": "pnpm -r --parallel --if-present typecheck",
    "lint": "pnpm -r --parallel --if-present lint",
    "doctor": "pnpm --filter naro-app run doctor && pnpm --filter naro-service-app run doctor",
    "ui:audit": "node scripts/ui-audit.mjs",
    "service:live-gate": "node scripts/service-live-gate.mjs",
    "ci:mobile": "pnpm lint && pnpm typecheck && pnpm test && pnpm ui:audit && pnpm run doctor",
    "format": "pnpm -r --parallel --if-present format"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "expo-doctor": "^1.18.18",
    "vitest": "^2.1.8",
    "playwright": "^1.59.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "zod": "3.23.8",
      "react-hook-form": "7.53.0"
    }
  }
}
