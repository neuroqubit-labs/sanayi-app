{
  "name": "naro-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:app": "pnpm --filter naro-app start",
    "dev:service": "pnpm --filter naro-service-app start",
    "capture:legacy-screens": "node scripts/capture-legacy-screens.mjs",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "pnpm -r --parallel lint",
    "format": "pnpm -r --parallel format"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "zod": "3.23.8",
      "react-hook-form": "7.53.0"
    }
  }
}
